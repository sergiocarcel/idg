rules_version = '2';

// Reglas básicas de Firebase Storage para subida de fotos de obras y documentos de RRHH
service firebase.storage {
  match /b/{bucket}/o {
    
    // Raiz de los archivos
    match /{allPaths=**} {
      // Todo usuario con cuenta corporativa (Auth) puede ver y subir/descargar archivos
      allow read, write: if request.auth != null;
    }
    
  }
}
