# White-label: nombre del CRM y empresa (configurable por cliente)
VITE_APP_NAME=Mi Empresa CRM
VITE_APP_COMPANY=Mi Empresa

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Cloudinary Integration (Storage)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# EmailJS (envío de emails gratuito - https://emailjs.com)
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Google Calendar (OAuth 2.0 via Google Identity Services - NO usa Firebase Auth)
# Crear en: console.cloud.google.com → APIs → Credenciales → OAuth 2.0 Client ID (tipo Web)
# Añadir orígenes autorizados: http://localhost:5173 y tu dominio de producción
# Habilitar: Google Calendar API en "APIs habilitadas"
VITE_GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com

# Modo de gestión de usuarios (Fase 2 - Bloque 1):
#   spark = gratuito (default), usuarios se crean/eliminan manualmente en Firebase Console
#   blaze = de pago (tarjeta requerida), el CRM crea/elimina/suspende/resetea vía Cloud Functions
# Para activar Blaze: cambiar a 'blaze', ejecutar "cd functions && npm install",
# luego "firebase deploy --only functions" en el proyecto Firebase con plan Blaze.
VITE_FIREBASE_MODE=spark

# FCM Web Push (solo Blaze — se ignora en Spark)
# VAPID key: Firebase Console → Project Settings → Cloud Messaging → Web Push Certificates → "Key pair"
VITE_FIREBASE_VAPID_KEY=your_vapid_key_here
