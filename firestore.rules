rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar para comprobar Auth
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Portal de colaboradores: permite lectura pública de la colección
    // 'colaboradores' para verificar email+PIN y ver documentos.
    // El PIN actúa como capa de control de acceso.
    match /colaboradores/{colabId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    // Regla base para TODAS LAS COLECCIONES del CRM:
    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); 
    }
    
    // Colección CONFIDENCIAL: 'config'
    match /config/{configDoc} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
